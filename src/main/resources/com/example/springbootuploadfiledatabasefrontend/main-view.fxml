<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.springbootuploadfiledatabasefrontend.controller.FileController"
      spacing="10">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <Label text="File Manager" style="-fx-font-size: 18; -fx-font-weight: bold;"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="Choose File" onAction="#chooseFile"/>
        <Label fx:id="selectedFileLabel" text="No file selected"/>
        <Button fx:id="uploadButton" text="Upload" onAction="#uploadFile"/>
    </HBox>

    <TableView fx:id="fileTable">
        <columns>
            <TableColumn fx:id="nameColumn" text="Name" prefWidth="180"/>
            <TableColumn fx:id="typeColumn" text="Type" prefWidth="150"/>
            <TableColumn fx:id="sizeColumn" text="Size" prefWidth="100"/>
            <TableColumn fx:id="urlColumn" text="URL" prefWidth="300"/>
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="Refresh" onAction="#loadFiles"/>
        <Button fx:id="updateButton" text="Update" onAction="#updateFile"/>
        <Button fx:id="deleteButton" text="Delete" onAction="#deleteFile"/>
    </HBox>

    <Label fx:id="statusLabel" text="Ready." style="-fx-text-fill: gray;"/>
</VBox>