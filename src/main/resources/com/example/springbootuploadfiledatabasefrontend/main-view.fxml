<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.springbootuploadfiledatabasefrontend.controller.FileController"
      spacing="10">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <Label text="Uploaded Files"/>

    <Button text="Refresh" onAction="#loadFiles"/>

    <TableView fx:id="fileTable">
        <columns>
            <TableColumn fx:id="nameColumn" text="Name" prefWidth="180"/>
            <TableColumn fx:id="typeColumn" text="Type" prefWidth="150"/>
            <TableColumn fx:id="sizeColumn" text="Size" prefWidth="100"/>
            <TableColumn fx:id="urlColumn" text="URL" prefWidth="300"/>
        </columns>
    </TableView>
</VBox>